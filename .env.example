APP_PORT=8080
# 本地打包镜像部署时使用；需与 docker load 后的镜像名一致
CLASSIFIER_IMAGE=classifier
CLASSIFIER_TAG=local
# 极空间存储根路径，容器挂载后可访问该路径下所有目录
NAS_ROOT=/tmp/zfsv3
# 初始扫描目录和目标目录（必须在 NAS_ROOT 下）
SOURCE_DIR=/tmp/zfsv3/sda1/data/source
TARGET_DIR=/tmp/zfsv3/sda1/data/target
# 删除暂存目录（建议放在 NAS_ROOT 下；如果不配置，Compose 会使用 /config/delete-staging）
DELETE_STAGING_DIR=/tmp/zfsv3/sda1/data/classifier-delete-staging

# Windows 本地开发示例（按需取消注释）
# SOURCE_DIR=C:\\Data\\classifier\\source
# TARGET_DIR=C:\\Data\\classifier\\target
# CONFIG_DIR=C:\\Data\\classifier\\config
# DELETE_STAGING_DIR=C:\\Data\\classifier\\delete-staging

# macOS 本地开发示例（按需取消注释）
# SOURCE_DIR=/Users/yourname/classifier/source
# TARGET_DIR=/Users/yourname/classifier/target
# CONFIG_DIR=/Users/yourname/classifier/config
# DELETE_STAGING_DIR=/Users/yourname/classifier/delete-staging

MAX_CONCURRENCY=3
TZ=Asia/Shanghai
CPU_LIMIT=2.0
MEMORY_LIMIT=1G

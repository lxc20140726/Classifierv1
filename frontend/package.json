{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:fullstack": "playwright test -c playwright.fullstack.config.ts",
    "e2e:fullstack:tree": "E2E_PRINT_TREE=1 playwright test -c playwright.fullstack.config.ts",
    "e2e:fullstack:tags": "playwright test -c playwright.fullstack.config.ts",
    "e2e:fullstack:tags:tree": "E2E_PRINT_TREE=1 playwright test -c playwright.fullstack.config.ts",
    "e2e:docker": "playwright test -c playwright.docker.config.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^6.30.2",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.55.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web": "^0.0.344",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
